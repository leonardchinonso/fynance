# HTTP server port for both the web UI and REST API (single port serves everything)
# Pick something unlikely to collide with common dev servers
FYNANCE_PORT=7433

# Full path to the SQLite database file
# Leave empty to use the OS default: ~/.local/share/fynance/fynance.db (Linux),
# ~/Library/Application Support/fynance/fynance.db (macOS), %APPDATA%\fynance\fynance.db (Windows)
# In Docker this is set automatically to /home/fynance/data/fynance.db
FYNANCE_DB_PATH=

# Bind address for the HTTP server
# Default 127.0.0.1 restricts access to localhost only (recommended for local use)
# Set to 0.0.0.0 to listen on all interfaces (done automatically in Docker so port mapping works)
FYNANCE_HOST=127.0.0.1

# Anthropic API key for LLM-based CSV import (https://console.anthropic.com/).
# Required for `fynance import`. Without this key the import command exits
# with an actionable error message.
FYNANCE_ANTHROPIC_API_KEY=

# Claude model used by the CSV import parser.
# Defaults to claude-haiku-4-5-20251001 (fast and cheap for structured extraction).
FYNANCE_IMPORT_LLM_MODEL=claude-haiku-4-5-20251001

# File-level detection confidence threshold [0.0–1.0].
# If the LLM's confidence that a file is a valid bank statement falls below
# this, the import fails hard rather than ingesting garbage.
# Default 0.80 — unknown-but-valid banks typically score ≥ 0.85.
FYNANCE_IMPORT_MIN_DETECT_CONF=0.80

# Row-level confidence threshold [0.0–1.0].
# Rows below this are skipped with a warning; the rest of the file still ingests.
# Default 0.70 — covers preamble lines, totals rows, and ambiguous formats.
FYNANCE_IMPORT_MIN_ROW_CONF=0.70

# Log verbosity level
# Options: trace, debug, info, warn, error
FYNANCE_LOG_LEVEL=info

# Frontend: force mock data mode (disables live API toggle in settings).
# Set to "true" for demo/preview deployments. Leave empty or unset for normal use.
VITE_MOCK_ONLY=

# Path to additional documentation for AI agents building against this environment
# Claude and other agents will read files at this path for environment-specific context
# Example: /home/user/docs/fynance-env-notes.md
FYNANCE_ADDITIONAL_DOCS=
